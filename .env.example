# Story Forge Configuration Template
# Copy this file to .env and fill in your values

# Application
APP_ENV=development
PORT=8080

# Authentication Mode
# Set AUTH_ENABLED=1 to enforce Google OAuth login (default: off for local dev)
# When AUTH_ENABLED is not set or is 0, dev mode can be used
AUTH_ENABLED=0

# Dev Mode (bypasses Google OAuth with a local dev user)
# Set DEV_MODE=1 to auto-login as dev user without Google OAuth
DEV_MODE=1
DEV_USER_EMAIL=dev@story-forge.local
DEV_USER_NAME=Dev User
DEV_USER_ID=dev-user-001

# Database
DATABASE_URL=sqlite:///./data/story_forge.db

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MiniMax TTS API
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_VOICE_ID=your-voice-id

# Google Cloud Storage (for backups)
GCS_BUCKET_NAME=your-bucket-name
GCS_SERVICE_ACCOUNT_KEY=your-service-account-json

# OpenClaw Secrets (for production)
# In production, secrets are fetched from OpenClaw's secret manager
