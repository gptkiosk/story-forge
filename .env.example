# Story Forge Configuration Template
# Copy this file to .env and fill in your values

# Application
APP_ENV=development
PORT=8080

# Database
DATABASE_URL=sqlite:///./data/story_forge.db

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MiniMax TTS API
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_VOICE_ID=your-voice-id

# Google Cloud Storage (for backups)
GCS_BUCKET_NAME=your-bucket-name
GCS_SERVICE_ACCOUNT_KEY=your-service-account-json

# OpenClaw Secrets (for production)
# In production, secrets are fetched from OpenClaw's secret manager
