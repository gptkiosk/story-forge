# Story Forge Configuration Template
# Copy this file to .env and fill in your values

# Application
APP_ENV=development
PORT=8000

# Authentication
# For real Google login set AUTH_ENABLED=1 and DEV_MODE=0.
# REVIEW_MODE may be left unset; when unset Story Forge automatically uses
# review mode only when auth is not enforced or dev mode is enabled.
AUTH_ENABLED=0
DEV_MODE=1
DEV_USER_EMAIL=dev@story-forge.local
DEV_USER_NAME=Dev User
DEV_USER_ID=dev-user-001
# REVIEW_MODE=0

# Database
DATABASE_URL=sqlite:///./data/story_forge.db

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Optional backup / provider defaults
STORY_FORGE_USB_PATH=/Volumes/xtra-ssd
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_APP_NAME=Story Forge
OPENROUTER_SITE_URL=http://localhost:5173

# TTS Keys can be configured from the app and stored in Keychain.
MINIMAX_API_KEY=your-minimax-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
